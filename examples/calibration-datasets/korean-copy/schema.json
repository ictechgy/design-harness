{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-harness.dev/schemas/korean-copy-fixture-calibration.json",
  "title": "Korean Copy Fixture Calibration Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "fixturePath",
    "source",
    "license",
    "redistributionStatus",
    "synthetic",
    "derived",
    "josaHedgePolicy",
    "expectedFindings",
    "shouldNotFlag"
  ],
  "properties": {
    "schemaVersion": {
      "const": "korean-copy-fixtures/v2"
    },
    "fixturePath": {
      "type": "string",
      "pattern": "^examples/ui-quality-fixtures/(korean-[^/]+|korean/[^/]+)\\.html$"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "redistributionStatus": {
      "enum": [
        "allowed",
        "internal-only",
        "prohibited"
      ]
    },
    "synthetic": {
      "type": "boolean"
    },
    "derived": {
      "type": "boolean"
    },
    "josaHedgePolicy": {
      "enum": [
        "flag",
        "allow"
      ]
    },
    "expectedFindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "checkName",
          "count"
        ],
        "properties": {
          "checkName": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "count": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "shouldNotFlag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registeredCheckNames",
        "futureCriteria"
      ],
      "properties": {
        "registeredCheckNames": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "futureCriteria": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "criterionId",
              "rationale"
            ],
            "properties": {
              "criterionId": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$"
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
