{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-harness.dev/schemas/report.schema.json",
  "title": "ReportManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "harnessVersion",
    "runId",
    "format",
    "reportPath",
    "sourceAuditPath",
    "sections",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.2"
    },
    "harnessVersion": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "enum": [
        "markdown"
      ]
    },
    "reportPath": {
      "type": "string",
      "minLength": 1
    },
    "sourceAuditPath": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    }
  }
}
