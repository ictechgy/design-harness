{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-harness.dev/schemas/design-guide.schema.json",
  "title": "DesignGuide",
  "description": "Closed authoring envelope for the Design Harness v0.5a generation profile and optional v0.5b audit policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tokens",
    "prohibitions",
    "signatureElement"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.2"
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "color",
        "font",
        "spacing",
        "radius"
      ],
      "properties": {
        "color": {
          "type": "object"
        },
        "font": {
          "type": "object"
        },
        "spacing": {
          "type": "object"
        },
        "radius": {
          "type": "object"
        }
      }
    },
    "prohibitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "signatureElement": {
      "type": "string",
      "minLength": 1
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fontFamily"
      ],
      "properties": {
        "fontFamily": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "additionalAllowedFamilies": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "uniqueItems": true,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "value",
                  "kind"
                ],
                "properties": {
                  "value": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                  },
                  "kind": {
                    "type": "string",
                    "enum": [
                      "named",
                      "generic"
                    ]
                  }
                }
              }
            },
            "ignoreSelectors": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              }
            }
          }
        }
      }
    }
  }
}
