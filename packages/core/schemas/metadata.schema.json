{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-harness.dev/schemas/metadata.schema.json",
  "title": "RunMetadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "harnessVersion",
    "runId",
    "status",
    "targetUrl",
    "startedAt",
    "finishedAt",
    "durationMs",
    "viewportPresets",
    "toolVersions",
    "outputFiles",
    "failedChecks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1"
    },
    "harnessVersion": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "failed"
      ]
    },
    "targetUrl": {
      "type": "string",
      "pattern": "^https?://"
    },
    "startedAt": {
      "type": "string",
      "minLength": 1
    },
    "finishedAt": {
      "type": "string",
      "minLength": 1
    },
    "durationMs": {
      "type": "number",
      "minimum": 0
    },
    "viewportPresets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "width",
          "height",
          "deviceScaleFactor",
          "isMobile"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "deviceScaleFactor": {
            "type": "number",
            "minimum": 0.1
          },
          "isMobile": {
            "type": "boolean"
          }
        }
      }
    },
    "toolVersions": {
      "type": "object"
    },
    "browserVersion": {
      "type": "string"
    },
    "outputFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failedChecks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
