{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-harness.dev/schemas/viewport-preset.schema.json",
  "title": "ViewportPreset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "width",
    "height",
    "deviceScaleFactor",
    "isMobile"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "deviceScaleFactor": {
      "type": "number",
      "minimum": 0.1
    },
    "isMobile": {
      "type": "boolean"
    }
  }
}
