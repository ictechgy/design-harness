{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-harness.dev/schemas/finding.schema.json",
  "title": "Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "severity",
    "confidence",
    "viewport",
    "evidenceRefs",
    "problem",
    "recommendation",
    "checkName"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "layout",
        "hierarchy",
        "interaction",
        "accessibility",
        "content",
        "responsiveness",
        "visual-polish",
        "task-fit"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "viewport": {
      "type": "string",
      "minLength": 1
    },
    "selector": {
      "type": "string"
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    },
    "checkName": {
      "type": "string",
      "minLength": 1
    },
    "criterionId": {
      "type": "string",
      "minLength": 1
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "determinism": {
      "type": "string",
      "enum": [
        "deterministic",
        "heuristic",
        "subjective"
      ]
    },
    "resultKind": {
      "type": "string",
      "enum": [
        "failure",
        "risk",
        "needs-review"
      ]
    },
    "runtime": {
      "type": "string",
      "enum": [
        "static-dom",
        "computed-style",
        "viewport-sweep",
        "interaction-simulation",
        "human-review",
        "model-judged"
      ]
    },
    "observed": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "object"
        },
        {
          "type": "array"
        },
        {
          "type": "null"
        }
      ]
    },
    "expected": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "object"
        },
        {
          "type": "array"
        },
        {
          "type": "null"
        }
      ]
    },
    "humanReviewRecommended": {
      "type": "boolean"
    }
  }
}
