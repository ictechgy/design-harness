{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://design-harness.dev/schemas/critique.schema.json",
  "title": "Critique",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "harnessVersion",
    "id",
    "auditRunId",
    "summary",
    "evidenceRefs",
    "recommendations",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1"
    },
    "harnessVersion": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "auditRunId": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    }
  }
}
