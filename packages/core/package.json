{
  "name": "@design-harness/core",
  "version": "0.5.0",
  "description": "Core schemas, validation, scoring, and report rendering for Design Harness.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/ictechgy/design-harness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ictechgy/design-harness.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ictechgy/design-harness/issues"
  },
  "keywords": [
    "ui-ux",
    "visual-qa",
    "ai-agents",
    "schemas",
    "design-systems"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "rubric.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "validate": "pnpm run build && node dist/validate-schemas.js"
  }
}
