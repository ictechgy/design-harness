{
  "name": "@design-harness/core",
  "version": "0.1.0",
  "description": "Core schemas, validation, scoring, and report rendering for Design Harness.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "rubric.yaml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "validate": "pnpm run build && node dist/validate-schemas.js"
  }
}
