{
  "name": "@design-harness/visual-audit",
  "version": "0.3.0",
  "description": "Playwright-based visual audit runner for Design Harness.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/ictechgy/design-harness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ictechgy/design-harness.git",
    "directory": "packages/visual-audit"
  },
  "bugs": {
    "url": "https://github.com/ictechgy/design-harness/issues"
  },
  "keywords": [
    "ui-ux",
    "visual-qa",
    "ai-agents",
    "playwright",
    "accessibility"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@design-harness/core": "workspace:^",
    "playwright": "^1.49.1"
  }
}
