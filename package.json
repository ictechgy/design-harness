{
  "name": "design-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Model-agnostic UI/UX critique, visual QA, and iteration harness for AI coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "validate": "pnpm --filter @design-harness/core validate",
    "design-harness": "pnpm --filter @design-harness/cli start"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
