{
  "name": "design-harness",
  "version": "0.4.1",
  "private": true,
  "description": "Model-agnostic UI/UX critique, visual QA, and iteration harness for AI coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/ictechgy/design-harness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ictechgy/design-harness.git"
  },
  "bugs": {
    "url": "https://github.com/ictechgy/design-harness/issues"
  },
  "keywords": [
    "ui-ux",
    "visual-qa",
    "ai-agents",
    "frontend",
    "playwright",
    "accessibility",
    "design-systems"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "validate": "pnpm --filter @design-harness/core validate && pnpm validate:calibration-datasets && pnpm check:github-actions && pnpm check:agent-recipes && pnpm check:v0.3-integrations && pnpm check:enum-lockstep && pnpm check:criteria-policy && pnpm check:version-consistency && pnpm check:release-hook-policy && pnpm check:core-purity && pnpm check:package-boundaries && pnpm check:deps-policy && pnpm check:tracked-hygiene",
    "check:enum-lockstep": "node scripts/check-enum-lockstep.mjs",
    "check:criteria-policy": "node scripts/check-criteria-policy.mjs",
    "check:version-consistency": "node scripts/check-version-consistency.mjs",
    "check:release-hook-policy": "node scripts/check-release-hook-policy.mjs",
    "check:core-purity": "node scripts/check-core-purity.mjs",
    "check:package-boundaries": "node scripts/check-package-boundaries.mjs && node scripts/check-package-boundaries-regressions.mjs",
    "check:deps-policy": "node scripts/check-deps-policy.mjs",
    "check:tracked-hygiene": "node scripts/check-tracked-hygiene.mjs",
    "validate:calibration-datasets": "pnpm validate:midjourney-lab && pnpm validate:korean-copy && pnpm check:midjourney-policy",
    "validate:midjourney-lab": "node examples/calibration-datasets/midjourney-reference-lab/validate-manifest.mjs examples/calibration-datasets/midjourney-reference-lab/manifest.example.jsonl && node examples/calibration-datasets/midjourney-reference-lab/validate-regressions.mjs",
    "validate:korean-copy": "node examples/calibration-datasets/korean-copy/validate-manifest.mjs && node examples/calibration-datasets/korean-copy/validate-regressions.mjs && node scripts/run-calibration-regressions.mjs",
    "check:midjourney-policy": "node scripts/check-midjourney-reference-policy.mjs",
    "check:github-actions": "node scripts/check-github-action-artifacts.mjs",
    "check:agent-recipes": "node scripts/check-agent-recipes.mjs",
    "check:v0.3-integrations": "node scripts/check-v0-3-integrations.mjs",
    "design-harness": "pnpm --filter @design-harness/cli start",
    "comment:pr": "node scripts/render-pr-comment.mjs",
    "scenario:audit": "node scripts/run-scenario-audit.mjs",
    "mcp:tools": "node scripts/mcp-adapter.mjs list-tools",
    "playwright:install": "pnpm --filter @design-harness/visual-audit exec playwright install chromium",
    "example:serve": "node scripts/serve-static.mjs examples/merchant-dashboard 4173",
    "smoke:example": "node scripts/run-example-smoke.mjs",
    "smoke:copy": "node scripts/run-copy-smoke.mjs",
    "calibrate:fixtures": "pnpm validate:korean-copy && node scripts/run-calibration.mjs",
    "smoke:packed-cli": "node scripts/verify-packed-cli.mjs",
    "pack:dry-run": "pnpm --filter @design-harness/core pack --dry-run && pnpm --filter @design-harness/copy-audit pack --dry-run && pnpm --filter @design-harness/visual-audit pack --dry-run && pnpm --filter @design-harness/cli pack --dry-run",
    "release:check": "pnpm build && pnpm typecheck && pnpm test && pnpm validate && pnpm pack:dry-run && pnpm smoke:packed-cli"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
